# API Configuration
LYRICS_API_KEY=your_google_ai_studio_key_here                        # Google AI Studio / Gemini API Key
LYRICS_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
LYRICS_MODEL=gemini-3.1-pro-preview                                  # 默认逻辑模型 (Gemini 官方接口)
GEMINI_FALLBACK_MODELS=gemini-3-flash-preview,gemini-2.5-flash,gemini-2.5-flash-lite # Pro 高负载时自动降级模型
GEMINI_PRIMARY_TIMEOUT_MS=120000                                     # Pro 单次等待时长，超时后降级
GEMINI_PRIMARY_MAX_ATTEMPTS=1                                        # Pro 默认只试一次，避免高峰期卡住
GEMINI_FALLBACK_TIMEOUT_MS=120000                                    # Flash / Lite 单次等待时长
GEMINI_FALLBACK_MAX_ATTEMPTS=2                                       # Flash / Lite 可短重试一次
LYRICS_PROXY_URL=                                                    # 可选：覆盖默认代理地址
HTTPS_PROXY=http://127.0.0.1:7897                                    # 可选：本地 Clash / HTTP 代理
HTTP_PROXY=http://127.0.0.1:7897                                     # 可选：本地 Clash / HTTP 代理
DEEPSEEK_BASE_URL=https://api.deepseek.com                              # DeepSeek 官方 OpenAI 兼容接口
DEEPSEEK_USE_PROXY=false
WRITER_MODEL=deepseek-v4-pro                                            # 写作模型 (DeepSeek V4 Pro)

# Zhiling Gateway fallback (用于首页模型切换；默认首选 gemini-3.1-pro-preview，可切换官方 Gemini / gpt-5.5 / claude-sonnet-4-6 / claude-opus-4-6 / gemini-3-pro-preview / DeepSeek-V4-Flash / DeepSeek-V4-Pro)
GATEWAY_API_KEY=your_zhiling_gateway_token_here
GATEWAY_BASE_URL=https://getways-jumu.zeelin.cn/v1
GATEWAY_MODEL=gemini-3.1-pro-preview
GATEWAY_TIMEOUT_MS=180000
GATEWAY_MAX_ATTEMPTS=2

# Server Configuration
PORT=3000                                                              # 服务器端口
